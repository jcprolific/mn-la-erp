  {
    "id": "TC001",
    "title": "Owner/Admin can access Warehouse module from Master Dashboard",
    "description": "Verifies an authenticated Owner/Admin can see dashboard modules and navigate to the Warehouse dashboard.",
    "category": "Master Dashboard (Role-based)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login.html"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/index.html\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Warehouse\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Warehouse\" card/module"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warehouse.html\""
      }
    ]
  },

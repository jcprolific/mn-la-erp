  {
    "id": "TC014",
    "title": "Store Associate receives inventory into assigned store and sees updated branch stock",
    "description": "Verifies a Store Associate can submit an Inventory In transaction for their assigned store and then see the updated quantity in Branch Stocks.",
    "category": "Store Inventory In",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login.html"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/store-inventory-in.html\""
      },
      {
        "type": "action",
        "description": "Select \"Store A\" from the branch dropdown"
      },
      {
        "type": "action",
        "description": "Type \"TEST-PRODUCT-001\" into the product/barcode input field"
      },
      {
        "type": "action",
        "description": "Type \"5\" into the quantity field"
      },
      {
        "type": "action",
        "description": "Click the \"Submit\" or \"Receive\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Success\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Branch Stocks\" navigation link/menu item"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/store-branch-stocks.html\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"TEST-PRODUCT-001\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Store A\" is visible"
      }
    ]
  },
